# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
# Local development — direct Supabase connection
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxx.supabase.co:5432/postgres

# Cloud deployment (Render / Railway / Fly.io) — use Supabase POOLER URL
# Supabase Dashboard → Settings → Database → Connection Pooling → Transaction mode (port 6543)
# DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Local PostgreSQL (no Supabase)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=content_broadcasting
# DB_USER=postgres
# DB_PASSWORD=your_password_here

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# ─── File Upload ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_DEST=uploads/

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Redis Caching (optional — omit all to disable caching) ─────────────────
# REDIS_HOST=redis-xxxxx.c14.us-east-1-3.ec2.cloud.redislabs.com
# REDIS_PORT=13467
# REDIS_USERNAME=default
# REDIS_PASSWORD=your_redis_password

# ─── S3 Upload (optional — omit to use local disk storage) ──────────────────
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=ap-south-1
# AWS_BUCKET_NAME=content-broadcasting-bucket

# ─── Default Principal (used by seed script) ─────────────────────────────────
PRINCIPAL_NAME=Principal Admin
PRINCIPAL_EMAIL=principal@school.com
PRINCIPAL_PASSWORD=Principal@123
