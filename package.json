{
  "name": "content-broadcasting-system",
  "version": "1.0.0",
  "description": "Content Broadcasting System for educational environments — Backend API",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "prisma generate && nodemon src/app.js",
    "seed": "node src/scripts/seed.js",
    "postinstall": "prisma generate",
    "db:push": "npx prisma db push",
