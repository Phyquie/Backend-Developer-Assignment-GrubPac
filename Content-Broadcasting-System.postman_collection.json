   "name": "Authentication",
   "item": [
    {
     "name": "Register New Teacher — Success",
     "request": {
      "method": "POST",
      "header": [
       {
        "key": "Content-Type",
        "value": "application/json"
       }
      ],
      "url": {
       "raw": "{{base_url}}/auth/register",
       "host": [
        "{{base_url}}"
       ],
       "path": [
        "auth",
        "register"
       ]
      },
      "body": {
       "mode": "raw",
       "raw": "{\n \"name\": \"Demo Teacher\",\n \"email\": \"demo.teacher@school.com\",\n \"password\": \"Demo@1234\"\n}"
      }
     },
     "event": [
      {
       "listen": "test",
       "script": {
        "exec": [
         "pm.test('Status 201', () => pm.response.to.have.status(201));",
         "pm.test('Teacher created', () => {",
         " const r = pm.response.json();",
         " pm.expect(r.success).to.be.true;",
         " pm.expect(r.data.role).to.equal('teacher');",
         " pm.expect(r.data).to.not.have.property('password_hash');",
         "});"
        ]
       }
      }
     ]
    },
