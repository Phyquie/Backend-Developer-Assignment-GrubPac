  {
   "name": "Content — Teacher Upload Flow",
   "item": [
    {
     "name": "Upload Maths Content #1 — Active Window [201]",
     "description": "️ Select a local JPG/PNG/GIF file in the 'file' row before sending.",
     "request": {
      "method": "POST",
      "auth": {
       "type": "bearer",
       "bearer": [
        {
         "key": "token",
         "value": "{{teacher_token}}"
        }
       ]
      },
      "url": {
       "raw": "{{base_url}}/content",
       "host": [
        "{{base_url}}"
       ],
       "path": [
        "content"
       ]
      },
      "body": {
       "mode": "formdata",
       "formdata": [
        {
         "key": "file",
         "type": "file",
         "src": [],
         "description": "Select any JPG/PNG/GIF (max 10MB)"
        },
        {
         "key": "title",
         "value": "Maths Chapter 1 — Algebra Basics",
         "type": "text"
        },
        {
         "key": "subject",
         "value": "maths",
         "type": "text"
        },
        {
         "key": "description",
         "value": "Introduction to algebraic expressions",
         "type": "text"
        },
        {
         "key": "start_time",
         "value": "{{start_active}}",
         "type": "text",
         "description": "Set by pre-request script"
        },
        {
         "key": "end_time",
         "value": "{{end_active}}",
         "type": "text",
         "description": "Set by pre-request script"
        },
        {
         "key": "rotation_duration",
         "value": "5",
         "type": "text"
        }
       ]
      }
     },
     "event": [
      {
       "listen": "prerequest",
       "script": {
        "exec": [
         "const now = new Date();",
         "pm.collectionVariables.set('start_active', new Date(now.getTime() - 3600000).toISOString());",
         "pm.collectionVariables.set('end_active', new Date(now.getTime() + 86400000).toISOString());"
        ]
       }
      },
      {
       "listen": "test",
       "script": {
        "exec": [
         "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
         "pm.test('Content record returned', () => {",
         " const r = pm.response.json();",
         " pm.expect(r.success).to.be.true;",
         " pm.expect(r.data.id).to.be.a('string');",
         " pm.expect(r.data.status).to.equal('uploaded');",
         " pm.expect(r.data.subject).to.equal('maths');",
         " pm.expect(r.data.schedule).to.not.be.null;",
         "});",
         "const r = pm.response.json();",
         "if (r.data && r.data.id) {",
         " pm.collectionVariables.set('content_id', r.data.id);",
         " console.log(' content_id saved:', r.data.id);",
         "}"
        ]
       }
      }
     ]
    },
